# ============================================================
# .env.example — Copier vers .env et remplir les valeurs
# NE JAMAIS COMMITER .env dans git !
# ============================================================

# --- Ollama (LLM local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral                  # ou llama3, gemma2, phi3...

# --- Chemins des données ---
DATA_RAW_PATH=data/raw/improved_fraud_dataset.csv
DATA_PROCESSED_PATH=data/processed/
MODELS_PATH=models/

# --- API Config ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# --- Dashboard Config ---
DASHBOARD_PORT=8501

# --- Logging ---
LOG_LEVEL=INFO
